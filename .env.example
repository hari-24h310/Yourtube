# =====================================================
# BACKEND - MongoDB & JWT
# =====================================================
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname
JWT_SECRET=your_jwt_secret_key_here
PORT=5000

# =====================================================
# EMAIL OTP (Resend Service)
# =====================================================
# Get API key from https://resend.com
RESEND_API_KEY=re_your_api_key_here

# =====================================================
# SMS OTP (Twilio Service)
# =====================================================
# Get credentials from https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# =====================================================
# FIREBASE - Phone OTP Authentication
# =====================================================
# No backend env needed - config is in firebaseConfig.js
# Frontend will use credentials from firebaseConfig.js

# =====================================================
# CLERK - Email OTP Authentication
# =====================================================
# BACKEND (if needed for server-side verification)
CLERK_SECRET_KEY=sk_test_YrKAx2Lutw5XQKFueMf2vq2FeA9wBzMfU3zVpKifzM

# =====================================================
# FRONTEND - API URL
# =====================================================
REACT_APP_API_URL=http://localhost:5000
# or for Next.js:
# NEXT_PUBLIC_API_URL=http://localhost:5000

# =====================================================
# OPTIONAL - Fallback Email Service (Gmail SMTP)
# =====================================================
# Use this ONLY if Resend is down
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password

# =====================================================
# OPTIONAL - Payment Gateway
# =====================================================
RAZORPAY_KEY_ID=your_key_here
RAZORPAY_KEY_SECRET=your_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# =====================================================
# ENVIRONMENT
# =====================================================
NODE_ENV=development
